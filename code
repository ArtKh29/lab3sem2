struct Battery {
private:
    int currentCharge;
    int maxCharge;

public:
    Battery(int curr = 100, int max = 100) : currentCharge(curr), maxCharge(max) {}

    int getCurrentCharge() const { return currentCharge; }
    int getMaxCharge() const { return maxCharge; }

    void consumeCharge(int amount) {
        if (currentCharge - amount >= 0) {
            currentCharge -= amount;
        }
        else {
            currentCharge = 0;
        }
    }

    void replaceBattery(const Battery& newBattery) {
        currentCharge = newBattery.currentCharge;
        maxCharge = newBattery.maxCharge;
    }
};

class Clock {
private:
    int day;
    int month;
    int year;
    int hours;
    int minutes;
    int dayOfWeek;
    Battery battery;

public:
    Clock() : day(1), month(1), year(2000), hours(0), minutes(0),
        dayOfWeek(1), battery(100, 100) {
    }

    Clock(int d, int m, int y, int h, int min, int dow)
        : day(d), month(m), year(y), hours(h), minutes(min),
        dayOfWeek(dow), battery(100, 100) {
    }

    Clock(const Clock& other)
        : day(other.day), month(other.month), year(other.year),
        hours(other.hours), minutes(other.minutes),
        dayOfWeek(other.dayOfWeek), battery(other.battery) {
    }

    ~Clock() {}

    int getDay() const { return day; }
    int getMonth() const { return month; }
    int getYear() const { return year; }
    int getHours() const { return hours; }
    int getMinutes() const { return minutes; }
    int getDayOfWeek() const { return dayOfWeek; }

    void setDay(int d) { if (d > 0 && d <= 28) day = d; }
    void setMonth(int m) { if (m > 0 && m <= 12) month = m; }
    void setYear(int y) { year = y; }
    void setHours(int h) { if (h >= 0 && h < 24) hours = h; }
    void setMinutes(int min) { if (min >= 0 && min < 60) minutes = min; }
    void setDayOfWeek(int dow) { if (dow >= 0 && dow <= 6) dayOfWeek = dow; }

    std::string printInfo() const {
        std::ostringstream oss;
        oss << "Дата: " << day << "." << month << "." << year << "\n"
            << "Время: " << hours << ":" << (minutes < 10 ? "0" : "") << minutes << "\n"
            << "День недели: " << dayOfWeek << "\n"
            << "Батарейка: " << battery.getCurrentCharge() << "/" << battery.getMaxCharge() << " е.з.";
        return oss.str();
    }

    Clock& operator++() {
        if (battery.getCurrentCharge() > 0) {
            minutes++;
            if (minutes >= 60) {
                minutes = 0;
                hours++;
                if (hours >= 24) {
                    hours = 0;
                    day++;
                    dayOfWeek = (dayOfWeek + 1) % 7;
                    battery.consumeCharge(1);

                    if (day > 28) {
                        day = 1;
                        month++;
                        if (month > 12) {
                            month = 1;
                            year++;
                        }
                    }
                }
            }
        }
        return *this;
    }

    Clock operator++(int) {
        Clock temp = *this;
        ++(*this);
        return temp;
    }

    Clock operator+(int minutes) const {
        Clock result = *this;
        result.addMinutes(minutes);
        return result;
    }

    Clock operator/(int days) const {
        Clock newClock = *this;
        for (int i = 0; i < days; ++i) {
            ++newClock;
        }
        return newClock;
    }

    void addMinutes(int x) {
        for (int i = 0; i < x; ++i) {
            ++(*this);
        }
    }

    void replaceBattery(const Battery& newBattery) {
        battery.replaceBattery(newBattery);
    }
};

class Workshop {
private:
    std::string address;
    std::vector<Clock> clocksInWork;

public:
    Workshop() : address("Не указан") {}

    Workshop(const std::string& addr) : address(addr) {}

    Workshop(const std::string& addr, const std::vector<Clock>& clocks)
        : address(addr), clocksInWork(clocks) {
    }

    void replaceBatteryInClock(int clockIndex, const Battery& newBattery) {
        if (clockIndex >= 0 && clockIndex < static_cast<int>(clocksInWork.size())) {
            clocksInWork[clockIndex].replaceBattery(newBattery);
        }
    }

    std::string printInfo() const {
        std::ostringstream oss;
        oss << "Мастерская по адресу: " << address << "\n";
        oss << "Часов в работе: " << clocksInWork.size() << "\n";
        for (size_t i = 0; i < clocksInWork.size(); ++i) {
            oss << "Часы " << (i + 1) << " ---\n";
            oss << clocksInWork[i].printInfo() << "\n";
        }
        return oss.str();
    }

    std::string getAddress() const { return address; }
    size_t getClocksCount() const { return clocksInWork.size(); }
};

